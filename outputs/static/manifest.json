{
  "name": "Baker AI",
  "short_name": "Baker",
  "description": "Baker AI Chief of Staff — Mobile",
  "start_url": "/mobile",
  "display": "standalone",
  "background_color": "#0a0e14",
  "theme_color": "#0a6fdb",
  "icons": [
    {
      "src": "/static/baker-face-green.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/mobile",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": [".pdf", ".docx", ".xlsx", ".csv", ".txt", "application/pdf", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "text/csv", "text/plain"]
        }
      ]
    }
  }
}
