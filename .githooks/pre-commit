#!/usr/bin/env bash
# Baker pre-commit — five independent checks.
#
# Part 1: migration immutability         (HAS BYPASS — see below)
# Part 2: subagent location enforcement  (NO BYPASS — add to ~/.claude/agents/, not picker)
# Part 3: retired Anthropic model ID enforcement
#                                        (NO BYPASS — use claude-opus-4-6/4-7 or claude-sonnet-4-5/4-6)
# Part 4: render env-var wipe-pattern detection
#                                        (bypass via --no-verify only — 2026-05-17 wipe anchor)
# Part 5: /write-brief SOP enforcement on staged briefs
#                                        (bypass: Brief-SOP-bypass: <reason> trailer OR BAKER_BRIEF_SOP_BYPASS=1)
# Part 6: long-running-jobs ownership register validation
#                                        (NO BYPASS — fix the register entry)
#
# Activation (one-time per clone):
#   git config core.hooksPath .githooks
#
# Bypass paths (PART 1 ONLY — do NOT cover Parts 2 or 3):
#   1. "Migration-edit-authorized: <reason>" trailer in commit message.
#      Detected via .git/COMMIT_EDITMSG (works for editor and `-F` flows).
#   2. BAKER_MIGRATION_EDIT_AUTHORIZED=1 environment variable.
#      Required for `git commit -m "..."` flow because git does not write
#      COMMIT_EDITMSG before pre-commit fires when -m is used.
#
# Parts 2 and 3 have NO bypass by design. If you genuinely need to commit a
# `.claude/agents/*.md` file or a retired model ID string, surface the case
# to AH1; do not use `--no-verify` (project hard rule).
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---------------------------------------------------------------------------
# Part 2: subagent location enforcement (NO BYPASS — add to ~/.claude/agents/, not picker)
# Subagents live at user-global ~/.claude/agents/ post-HARNESS_SUBAGENT_MIGRATION_1 (2026-05-12).
# Filter `ACR` catches Added (A), Copied (C), Renamed (R) — closes the `git mv` rename gap.
# ---------------------------------------------------------------------------
AGENT_ADDS="$(git diff --cached --name-only --diff-filter=ACR | grep -E '^\.claude/agents/.+\.md$' || true)"
if [ -n "$AGENT_ADDS" ]; then
  echo "[pre-commit] BLOCKED (Part 2): subagent definitions must live at ~/.claude/agents/ (user-global), not in picker .claude/agents/." >&2
  echo "[pre-commit] Offending paths:" >&2
  echo "$AGENT_ADDS" | sed 's/^/  - /' >&2
  echo "[pre-commit] Move the file to ~/.claude/agents/<name>.md and re-stage. NO BYPASS — Part 1 bypasses do not cover Part 2." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Part 3: retired Anthropic model ID enforcement (NO BYPASS — use claude-opus-4-6/4-7 or claude-sonnet-4-5/4-6)
# Anthropic deprecation 2026-04-14, retirement 2026-06-15.
# Exclude historical/audit-trail paths: briefs/, tasks/lessons.md, docs-site/.
# Also exclude .githooks/ — the enforcement code itself necessarily contains the literal strings.
# ---------------------------------------------------------------------------
RETIRED_IDS_REGEX='claude-(opus-4|sonnet-4)-20250514'
EXCLUDE_PATHS_REGEX='^briefs/|^tasks/lessons\.md$|^docs-site/|^\.githooks/pre-commit$'

FILES_WITH_HITS="$(git diff --cached --name-only --diff-filter=ACMR | while read -r f; do
  [ -z "$f" ] && continue
  if echo "$f" | grep -qE "$EXCLUDE_PATHS_REGEX"; then
    continue
  fi
  if git diff --cached -- "$f" | grep -E '^\+' | grep -vE '^\+\+\+ ' | grep -qE "$RETIRED_IDS_REGEX"; then
    echo "$f"
  fi
done || true)"

if [ -n "$FILES_WITH_HITS" ]; then
  echo "[pre-commit] BLOCKED (Part 3): retired Anthropic model ID detected (claude-opus-4-20250514 or claude-sonnet-4-20250514)." >&2
  echo "[pre-commit] Anthropic retirement: 2026-06-15. Use claude-opus-4-6 / claude-opus-4-7 / claude-sonnet-4-5 / claude-sonnet-4-6." >&2
  echo "[pre-commit] Files with hits:" >&2
  echo "$FILES_WITH_HITS" | sed 's/^/  - /' >&2
  echo "[pre-commit] NO BYPASS. Exclusions: briefs/, tasks/lessons.md, docs-site/, .githooks/pre-commit (historical/audit-trail + enforcement code)." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Part 4: render env-var wipe-pattern detection (bypass via --no-verify only)
# Catches the 2026-05-17 wipe pattern at commit time. Layered above
# tools/render_env_guard.safe_env_put() runtime guard — the wrapper protects
# imported-Python paths; this hook protects bash/curl/raw-httpx escape routes.
# Pattern: PUT to /env-vars NOT followed by /KEY suffix (the foot-cannon URL).
# ---------------------------------------------------------------------------
RENDER_ENV_GUARD_ALLOWLIST_RE='^(tools/render_env_guard\.py|tests/test_render_env_guard\.py|tests/test_pre_commit_env_guard\.py|briefs/.*|tasks/lessons\.md|\.claude/rules/python-backend\.md|\.githooks/pre-commit)$'

STAGED_NON_ALLOWLISTED="$(git diff --cached --name-only --diff-filter=ACMR | grep -Ev "$RENDER_ENV_GUARD_ALLOWLIST_RE" || true)"

if [ -n "$STAGED_NON_ALLOWLISTED" ]; then
  OFFENDERS=""
  for f in $STAGED_NON_ALLOWLISTED; do
    if git diff --cached -- "$f" | grep -E '^\+' | grep -vE '^\+\+\+ ' | grep -qE 'services/[^/[:space:]"]+/env-vars($|[^/A-Za-z0-9_])'; then
      OFFENDERS="$OFFENDERS $f"
    fi
  done
  if [ -n "$OFFENDERS" ]; then
    echo "[pre-commit] BLOCKED (Part 4): staged diff contains a raw PUT to /env-vars (no /KEY suffix)." >&2
    echo "[pre-commit] This is the 2026-05-17 wipe pattern. Array-form PUT REPLACES the entire env set." >&2
    echo "[pre-commit] Use tools.render_env_guard.safe_env_put(service_id, KEY, value) — single-key PUT path." >&2
    echo "[pre-commit] Note: comments/docstrings in non-allowlisted files also block (move to briefs/ or python-backend.md if intentional)." >&2
    echo "[pre-commit] Offending files:" >&2
    for f in $OFFENDERS; do echo "  - $f" >&2; done
    echo "[pre-commit] If you genuinely need the array form (you don't), bypass with: git commit --no-verify" >&2
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# Part 5: /write-brief SOP enforcement on staged brief files (bypass via
# commit-msg trailer `Brief-SOP-bypass: <reason>` or env BAKER_BRIEF_SOP_BYPASS=1)
# Director-ratified 2026-05-23 evening (AH2 bus #790).
# MIRROR canonical at baker-vault/.githooks/brief_sop_check.sh.
# ---------------------------------------------------------------------------
if [ -x "$REPO_ROOT/.githooks/brief_sop_check.sh" ]; then
    "$REPO_ROOT/.githooks/brief_sop_check.sh" || exit $?
fi

# ---------------------------------------------------------------------------
# Part 6: long-running-jobs ownership register validation (NO BYPASS)
# LONG_RUNNING_JOB_OWNERSHIP_1: when config/long_running_jobs.yml is staged,
# reject ownerless / unknown-slug / bad-threshold / malformed entries before
# they can be committed. Runs only when the register is touched (fast no-op
# otherwise). Does NOT duplicate a hook runner — single inline check.
# ---------------------------------------------------------------------------
LRJ_STAGED="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^config/long_running_jobs\.yml$' || true)"
if [ -n "$LRJ_STAGED" ]; then
  if ! python3 scripts/validate_long_running_jobs.py >&2; then
    echo "[pre-commit] BLOCKED (Part 6): config/long_running_jobs.yml failed validation (see errors above)." >&2
    echo "[pre-commit] Fix the register entry (owner slug / threshold / cursor_source) and re-stage. NO BYPASS." >&2
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# Part 1: migration immutability (HAS BYPASS — see file header)
# ---------------------------------------------------------------------------
CHECK="scripts/check_applied_migrations.sh"
if [ ! -x "$CHECK" ]; then
  echo "[pre-commit] $CHECK missing or non-executable; skipping migration immutability check" >&2
  exit 0
fi

COMMIT_MSG_FILE="$(git rev-parse --git-path COMMIT_EDITMSG)"
exec "$CHECK" --commit-msg-file "$COMMIT_MSG_FILE"
